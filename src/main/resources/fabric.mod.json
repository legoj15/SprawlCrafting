{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "homepage": "https://github.com/legoj15/SprawlCrafting",
        "sources": "https://github.com/legoj15/SprawlCrafting",
        "issues": "https://github.com/legoj15/SprawlCrafting/issues"
    },
    "license": "${license}",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.legoj15.sprawlcrafting.platform.fabric.FabricMod"
        ],
        "client": [
            "com.legoj15.sprawlcrafting.platform.fabric.FabricClient"
        ],
        "jei_mod_plugin": [
            "com.legoj15.sprawlcrafting.compat.jei.SprawlCraftingJeiPlugin"
        ],
        "rei_client": [
            "com.legoj15.sprawlcrafting.platform.fabric.FabricReiPlugin"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-api": "*",
        "minecraft": "${minecraft_version}",
        "java": ">=${java_version}"
    },
    "suggests": {
        "jei": "*",
        "roughlyenoughitems": "*"
    }
}
  