# Local secrets for the release orchestrator. COPY THIS FILE to `secrets.ps1` (same folder) and fill
# in your tokens. `secrets.ps1` is gitignored (see root .gitignore); this `.example` is committed as
# the template. Invoke-Release.ps1 dot-sources `secrets.ps1` automatically if it exists.
#
# You only need these once you flip a store to "enabled": true in release.json. GitHub uses your
# existing `gh auth` (no token here). A dry run needs NO tokens at all.
#
# SECURITY: these are live publishing credentials. Rotate them immediately if this file (or any chat
# where they were shared) is ever exposed:
#   - Modrinth PAT (scope: "Create versions"):   https://modrinth.com/settings/pats
#   - CurseForge token:                          https://authors.curseforge.com/account/api-tokens
# Alternatively, delete `secrets.ps1` and set $env:MODRINTH_TOKEN / $env:CURSEFORGE_TOKEN yourself
# (e.g. as Windows User environment variables); the orchestrator reads whatever is in the process env.

$env:MODRINTH_TOKEN   = 'mr_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx'
$env:CURSEFORGE_TOKEN = 'xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'
